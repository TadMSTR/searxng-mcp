{
  "name": "@tadmstr/searxng-mcp",
  "version": "3.3.0",
  "description": "MCP server for SearXNG — private web search for Claude Code",
  "main": "build/src/index.js",
  "bin": {
    "searxng-mcp": "build/src/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TadMSTR/searxng-mcp.git"
  },
  "type": "module",
  "scripts": {
    "build": "tsc && chmod 755 build/src/index.js",
    "test": "vitest run --typecheck",
    "test:watch": "vitest --typecheck",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/"
  },
  "keywords": [
    "searxng",
    "mcp",
    "search"
  ],
  "author": "TadMSTR",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "build/src/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "iovalkey": "^0.3.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^4.1.3"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp": ">=8.4.0",
      "hono": ">=4.12.14",
      "@hono/node-server": ">=1.19.13"
    }
  }
}
